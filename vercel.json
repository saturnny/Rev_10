{
  "version": 2,
  "builds": [
    {
      "src": "api/stable.py",
      "use": "@vercel/python@3.12"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/stable.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12"
  },
  "functions": {
    "api/stable.py": {
      "runtime": "@vercel/python@3.12"
    }
  }
}
