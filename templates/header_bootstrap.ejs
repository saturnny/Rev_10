<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Time Tracking System' %></title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Nosso CSS Customizado -->
    <link rel="stylesheet" href="/static/css/bootstrap-theme.css">
    <link rel="stylesheet" href="/static/css/icons.css">
    <link rel="stylesheet" href="/static/css/design-tokens.css">
    
    <%- typeof extra_css !== 'undefined' ? extra_css : '' %>
</head>
<body>
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="app-layout">
        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-toggle" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">⏱️</div>
                    <span>Sistema de Atividades</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <% if (user.tipo_usuario === "Admin" || user.tipo_usuario === "Administrador") { %>
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Principal</div>
                    <a href="/dashboard" class="sidebar-item">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Administração</div>
                    <a href="/admin/usuarios" class="sidebar-item">
                        <i class="bi bi-person"></i>
                        <span>Usuários</span>
                    </a>
                    <a href="/admin/atividades" class="sidebar-item">
                        <i class="bi bi-list-task"></i>
                        <span>Gerenciar Atividades</span>
                    </a>
                    <a href="/admin/categorias" class="sidebar-item">
                        <i class="bi bi-tag"></i>
                        <span>Categorias</span>
                    </a>
                    <a href="/admin/lancamentos" class="sidebar-item">
                        <i class="bi bi-clock-history"></i>
                        <span>Lançamentos da Equipe</span>
                    </a>
                    <a href="/admin/sharepoint" class="sidebar-item">
                        <i class="bi bi-cloud-arrow-up"></i>
                        <span>Integração SharePoint</span>
                    </a>
                </div>
                <% } else { %>
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Menu</div>
                    <a href="/dashboard" class="sidebar-item">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="/lancamentos" class="sidebar-item">
                        <i class="bi bi-list-task"></i>
                        <span>Meus Lançamentos</span>
                    </a>
                    <a href="/perfil" class="sidebar-item">
                        <i class="bi bi-person"></i>
                        <span>Meu Perfil</span>
                    </a>
                </div>
                <% } %>
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar" style="background-color: #a00000;"><%= user.nome.substring(0, 2).toUpperCase() %></div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name text-truncate" style="max-width: 140px;"><%= user.nome %></div>
                        <div class="sidebar-user-role"><%= user.tipo_usuario %></div>
                    </div>
                </div>
                
                <div class="sidebar-logout">
                    <form method="post" action="/logout" style="display: inline;">
                        <button type="submit" class="btn w-100" style="background: white; color: #8b0000; border-radius: 8px; font-weight: 600; padding: 10px;" onclick="return confirm('Tem certeza que deseja sair do sistema?')">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            Sair
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="container-fluid p-4">
    <% } %>
