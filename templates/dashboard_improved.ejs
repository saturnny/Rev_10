function resetFormToNew() {
    // Resetar para novo lançamento
    document.getElementById('newLancamentoForm').action = '/novo-lancamento';
    document.getElementById('modal_data').readOnly = false;
    document.getElementById('modal_data').style.backgroundColor = '';
    document.getElementById('modal_data').style.fontWeight = '';
    document.querySelector('#newLancamentoModal .modal-title').innerHTML = '<i class="bi bi-plus-circle me-2"></i>Novo Lançamento';
    document.querySelector('#newLancamentoModal button[type="submit"]').innerHTML = '<i class="bi bi-check-circle me-1"></i>Salvar Lançamento';
    clearModalForm();
}

function filterTodayLancamentos() {
    const today = new Date().toISOString().split('T')[0];
    const tableRows = document.querySelectorAll('tbody tr');
    
    let todayCount = 0;
    let todayHours = 0;
    
    tableRows.forEach(row => {
        const dateCell = row.querySelector('td:first-child .badge');
        if (dateCell) {
            const dateStr = dateCell.textContent.trim();
            const [dia, mes, ano] = dateStr.split('/');
            const formattedDate = `${ano}-${mes.padStart(2, '0')}-${dia.padStart(2, '0')}`;
            
            if (formattedDate === today) {
                row.style.display = '';
                todayCount++;
                
                const durationCell = row.querySelector('.badge.bg-success');
                if (durationCell) {
                    const hours = parseFloat(durationCell.textContent.replace('h', ''));
                    todayHours += hours;
                }
            } else {
                row.style.display = 'none';
            }
        }
    });
    
    // Atualizar cards de estatísticas
    updateTodayStats(todayCount, todayHours);
}

function updateTodayStats(count, hours) {
    // Atualizar contador de lançamentos
    const launchCountElement = document.getElementById('today-launches-count');
    if (launchCountElement) {
        launchCountElement.textContent = count;
    }
    
    // Atualizar horas totais
    const hoursCountElement = document.getElementById('today-hours-count');
    if (hoursCountElement) {
        hoursCountElement.textContent = hours.toFixed(1);
    }
    
    // Calcular e atualizar horas pendentes (9 - horas lançadas)
    const pendingHoursElement = document.getElementById('pending-hours');
    if (pendingHoursElement) {
        const dailyTarget = 9.0; // Meta diária de 9 horas (8 trabalho + 1 almoço)
        const pending = Math.max(0, dailyTarget - hours);
        pendingHoursElement.textContent = pending.toFixed(1);
        
        // Adicionar classe de warning se estiver próximo ou acima da meta
        const card = pendingHoursElement.closest('.stat-card');
        if (card) {
            card.classList.remove('warning', 'success');
            if (hours >= dailyTarget) {
                card.classList.add('success');
            } else if (hours >= dailyTarget * 0.8) { // 80% da meta
                card.classList.add('warning');
            }
        }
    }
}

// Bootstrap validation
(function () {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.prototype.slice.call(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            } else {
                // Validar sobreposição de horários
                // Extrair ID do lançamento se for edição (action contém /editar-lancamento/)
                const formAction = form.getAttribute('action') || '';
                let lancamentoIdAtual = null;
                const match = formAction.match(/\/editar-lancamento\/(\d+)/);
                if (match) {
                    lancamentoIdAtual = match[1];
                }
                
                const validacao = validarSobreposicaoHorarios(lancamentoIdAtual);
                if (!validacao.valido) {
                    event.preventDefault();
                    event.stopPropagation();
                    alert(validacao.mensagem);
                    return;
                }
            }
            form.classList.add('was-validated');
        }, false);
    });
})();

