{% extends "base_bootstrap.html" %}

{% block title %}Dashboard - {{ user.nome }}{% endblock %}

{% block header %}
<div class="topbar">
    <div class="topbar-title">
        <h1>Dashboard</h1>
        <p>Bem-vindo(a) de volta, {{ user.nome }}!</p>
    </div>
</div>
{% endblock %}

{% block content %}
<!-- Estatísticas do Dashboard -->
<div class="stats-grid mb-4">
    <div class="stat-card primary">
        <div class="stat-icon">
            <i class="bi bi-clipboard-data"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="today-launches-count">0</div>
            <div class="stat-label">Lançamentos Hoje</div>
        </div>
    </div>
    
    <div class="stat-card success">
        <div class="stat-icon">
            <i class="bi bi-clock"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="today-hours-count">0.0</div>
            <div class="stat-label">Horas Hoje</div>
        </div>
    </div>
    
    <div class="stat-card info">
        <div class="stat-icon">
            <i class="bi bi-clock-history"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="pending-hours">0.0</div>
            <div class="stat-label">Horas Pendentes</div>
        </div>
    </div>
</div>

<!-- Recent Activities -->
<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h2 class="card-title">
                    <i class="bi bi-clock-history me-2"></i>
                    Atividades de Hoje
                </h2>
                <p class="card-description">Seus lançamentos do dia de hoje</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newLancamentoModal">
                    <i class="bi bi-plus-circle me-1"></i>
                    Novo Lançamento
                </button>
                <a href="/lancamentos" class="btn btn-outline-secondary">
                    <i class="bi bi-list-ul me-1"></i>
                    Ver Todos
                </a>
            </div>
        </div>
    </div>

    {% if lancamentos %}
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar3 me-1"></i>Data</th>
                    <th><i class="bi bi-clock me-1"></i>Início</th>
                    <th><i class="bi bi-clock-fill me-1"></i>Fim</th>
                    <th><i class="bi bi-list-task me-1"></i>Atividade</th>
                    <th><i class="bi bi-chat-text me-1"></i>Observação</th>
                    <th><i class="bi bi-hourglass-split me-1"></i>Duração</th>
                    <th style="width: 120px;"><i class="bi bi-gear me-1"></i>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for lancamento in lancamentos %}
                <tr>
                    <td>
                        <span class="badge bg-light text-dark">{{ lancamento.data.strftime('%d/%m/%Y') }}</span>
                    </td>
                    <td>{{ lancamento.hora_inicio.strftime('%H:%M') }}</td>
                    <td>{{ lancamento.hora_fim.strftime('%H:%M') }}</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary">{{ lancamento.atividade.nome }}</span>
                            <small class="text-muted">{{ lancamento.atividade.categoria.nome }}</small>
                        </div>
                    </td>
                    <td>
                        <small class="text-muted">{{ lancamento.observacao|default('-') }}</small>
                    </td>
                    <td>
                        <span class="badge bg-success">{{ "%.1f"|format(lancamento.duracao_horas) }}h</span>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-outline-primary edit-btn-caneta" 
                                   data-bs-toggle="tooltip" 
                                   data-bs-placement="top" 
                                   title="Editar lançamento"
                                   data-id="{{ lancamento.id }}"
                                   data-data="{{ lancamento.data.strftime('%Y-%m-%d') }}"
                                   data-inicio="{{ lancamento.hora_inicio.strftime('%H:%M') }}"
                                   data-fim="{{ lancamento.hora_fim.strftime('%H:%M') }}"
                                   data-atividade="{{ lancamento.atividade.id }}"
                                   data-observacao="{{ lancamento.observacao|default('') }}"
                                   onclick="openEditModal('{{ lancamento.id }}')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger delete-btn-caneta" 
                                    data-bs-toggle="tooltip" 
                                    data-bs-placement="top" 
                                    title="Excluir lançamento"
                                    data-id="{{ lancamento.id }}"
                                   onclick="deleteLancamento('{{ lancamento.id }}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card-body text-center py-5">
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-clipboard-x" style="font-size: 48px; color: var(--bs-secondary);"></i>
            </div>
            <div class="empty-state-title">Nenhum lançamento encontrado</div>
            <div class="empty-state-description">
                Você ainda não possui lançamentos de atividades registrados.
            </div>
            {% if user.tipo_usuario != "Admin" %}
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newLancamentoModal">
                <i class="bi bi-plus-circle me-1"></i>
                Adicionar Primeira Atividade
            </button>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>

<!-- New Lancamento Modal -->
<div class="modal fade" id="newLancamentoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>
                    Novo Lançamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form id="newLancamentoForm" method="post" action="/novo-lancamento" class="needs-validation" novalidate>
                <input type="hidden" name="return_url" value="/dashboard">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="modal_data" class="form-label">
                                <i class="bi bi-calendar3 me-1"></i>Data
                            </label>
                            <input type="date" id="modal_data" name="data" class="form-control" 
                                   value="{{ '2026-03-13' }}" required>
                            <div class="invalid-feedback">
                                Por favor, selecione uma data.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="modal_hora_inicio" class="form-label">
                                <i class="bi bi-clock me-1"></i>Hora Início
                            </label>
                            <input type="text" id="modal_hora_inicio" name="hora_inicio" class="form-control time-picker-input" 
                                   placeholder="Selecione o horário" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de início.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="modal_hora_fim" class="form-label">
                                <i class="bi bi-clock-fill me-1"></i>Hora Fim
                            </label>
                            <input type="text" id="modal_hora_fim" name="hora_fim" class="form-control time-picker-input" 
                                   placeholder="Selecione o horário" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de término.
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="modal_atividade_id" class="form-label">
                            <i class="bi bi-list-task me-1"></i>Atividade
                        </label>
                        <select id="modal_atividade_id" name="atividade_id" class="form-select" required>
                            <option value="">Selecione uma atividade</option>
                            {% for atividade in atividades %}
                            <option value="{{ atividade.id }}">
                                {{ atividade.nome }} ({{ atividade.categoria.nome }})
                            </option>
                            {% endfor %}
                        </select>
                        <div class="invalid-feedback">
                            Por favor, selecione uma atividade.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="modal_observacao" class="form-label">
                            <i class="bi bi-chat-text me-1"></i>Observação
                        </label>
                        <textarea id="modal_observacao" name="observacao" class="form-control" rows="3" 
                                  placeholder="Adicione uma observação sobre esta atividade (opcional)"></textarea>
                    </div>

                    <!-- Duration Display -->
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-hourglass-split me-2"></i>
                        <div id="modal_duration-display">
                            <strong>Duração Calculada:</strong>
                            <span class="badge bg-secondary">--</span>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" onclick="closeModalAndRedirect()">
                        <i class="bi bi-x-circle me-1"></i>
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-outline-secondary me-2" onclick="clearModalForm()">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Limpar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>
                        Salvar Lançamento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Lancamento Modal -->
<div class="modal fade" id="editLancamentoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil me-2"></i>
                    Editar Lançamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form id="editLancamentoForm" method="post">
                <input type="hidden" name="return_url" value="/dashboard">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="edit_data" class="form-label">
                                <i class="bi bi-calendar3 me-1"></i>Data do Lançamento
                            </label>
                            <input type="text" id="edit_data" name="data" class="form-control" readonly style="background-color: #f8f9fa; font-weight: 500;" required>
                            <div class="form-text text-muted">Data original do lançamento (não pode ser alterada)</div>
                            <div class="invalid-feedback">
                                Por favor, selecione uma data.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="edit_hora_inicio" class="form-label">
                                <i class="bi bi-clock me-1"></i>Hora Início
                            </label>
                            <input type="text" id="edit_hora_inicio" name="hora_inicio" class="form-control time-picker-input" 
                                   placeholder="Selecione o horário" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de início.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="edit_hora_fim" class="form-label">
                                <i class="bi bi-clock-fill me-1"></i>Hora Fim
                            </label>
                            <input type="text" id="edit_hora_fim" name="hora_fim" class="form-control time-picker-input" 
                                   placeholder="Selecione o horário" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de término.
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="edit_atividade_id" class="form-label">
                            <i class="bi bi-list-task me-1"></i>Atividade
                        </label>
                        <select id="edit_atividade_id" name="atividade_id" class="form-select" required>
                            <option value="">Selecione uma atividade</option>
                            {% for atividade in atividades %}
                            <option value="{{ atividade.id }}">
                                {{ atividade.nome }} ({{ atividade.categoria.nome }})
                            </option>
                            {% endfor %}
                        </select>
                        <div class="invalid-feedback">
                            Por favor, selecione uma atividade.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="edit_observacao" class="form-label">
                            <i class="bi bi-chat-text me-1"></i>Observação
                        </label>
                        <textarea id="edit_observacao" name="observacao" class="form-control" rows="3" 
                                  placeholder="Adicione uma observação sobre esta atividade (opcional)"></textarea>
                    </div>

                    <!-- Duration Display -->
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-hourglass-split me-2"></i>
                        <div id="edit_duration-display">
                            <strong>Duração Calculada:</strong>
                            <span class="badge bg-secondary">--</span>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-outline-secondary me-2" onclick="clearEditForm()">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Limpar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>
                        Atualizar Lançamento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Confirmar Exclusão
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="me-3">
                        <i class="bi bi-trash text-danger" style="font-size: 2.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-2">Tem certeza que deseja excluir este lançamento?</h6>
                        <p class="text-muted mb-0">Esta ação não poderá ser desfeita.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Cancelar
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash me-1"></i>
                    Sim, Excluir
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_css %}
<style>
/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

/* Canetinhas */
.edit-btn-caneta, .delete-btn-caneta {
    padding: 2px 6px;
    font-size: 11px;
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
}

.edit-btn-caneta {
    background-color: #f8f9fa;
    color: #0d6efd;
    border-color: #0d6efd;
}

.edit-btn-caneta:hover {
    background-color: #0d6efd;
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 2px 4px rgba(13, 110, 253, 0.2);
}

.delete-btn-caneta {
    background-color: #f8f9fa;
    color: #dc3545;
    border-color: #dc3545;
}

.delete-btn-caneta:hover {
    background-color: #dc3545;
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 2px 4px rgba(220, 53, 69, 0.2);
}

.edit-btn-caneta i, .delete-btn-caneta i {
    font-size: 12px;
    margin: 0;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f0f0f0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    align-items: center;
    gap: 16px;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
}

.stat-card.primary {
    border-left: 4px solid var(--bs-primary);
}

.stat-card.success {
    border-left: 4px solid var(--bs-success);
}

.stat-card.info {
    border-left: 4px solid #ffc107;
    background: white;
}

.stat-card.info .stat-icon {
    background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
}

.stat-card.info.warning {
    border-left: 4px solid #ff6b35;
    background: linear-gradient(135deg, #ffe5d9 0%, #ffccbc 100%);
}

.stat-card.info.warning .stat-icon {
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
}

.stat-card.info.success {
    border-left: 4px solid var(--bs-success);
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
}

.stat-card.info.success .stat-icon {
    background: linear-gradient(135deg, var(--bs-success) 0%, #198754 100%);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: white;
    flex-shrink: 0;
}

.stat-card.primary .stat-icon {
    background: linear-gradient(135deg, var(--bs-primary) 0%, var(--bs-primary-dark, #660000) 100%);
}

.stat-card.success .stat-icon {
    background: linear-gradient(135deg, var(--bs-success) 0%, #198754 100%);
}

.stat-card.info .stat-icon {
    background: linear-gradient(135deg, var(--bs-info) 0%, #0dcaf0 100%);
}

.stat-content {
    flex: 1;
}

.stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--bs-dark);
    line-height: 1;
    margin-bottom: 4px;
}

.stat-label {
    font-size: 0.9rem;
    color: var(--bs-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    
    .stat-card {
        padding: 20px;
    }
    
    .stat-icon {
        width: 50px;
        height: 50px;
        font-size: 1.2rem;
    }
    
    .stat-value {
        font-size: 2rem;
    }
}

/* Stat Badges */
.stat-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--bs-gray-100);
    border-radius: var(--bs-border-radius);
    border-left: 4px solid var(--bs-primary);
}

.stat-badge-success {
    border-left-color: var(--bs-success);
}

.stat-badge-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bs-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
}

.stat-badge-success .stat-badge-icon {
    background: var(--bs-success);
}

.stat-badge-content {
    flex: 1;
}

.stat-badge-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--bs-dark);
    line-height: 1;
}

.stat-badge-label {
    font-size: 12px;
    color: var(--bs-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Time Picker Input */
.time-picker-input {
    cursor: pointer;
    background: white;
}

.time-picker-input:hover {
    background-color: var(--bs-gray-100);
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .stat-badge {
        flex-direction: column;
        text-align: center;
        gap: 8px;
    }
    
    .stat-badge-icon {
        width: 50px;
        height: 50px;
        font-size: 20px;
    }
}
</style>
{% endblock %}

{% block extra_js %}
<script src="/static/js/notifications.js"></script>
<script>
// Calculate and display duration
function calculateDuration() {
    const inicio = document.getElementById('modal_hora_inicio').value;
    const fim = document.getElementById('modal_hora_fim').value;
    const durationDisplay = document.getElementById('modal_duration-display');
    const submitButton = document.querySelector('#newLancamentoModal button[type="submit"]');
    
    if (inicio && fim) {
        const [inicioHoras, inicioMinutos] = inicio.split(':').map(Number);
        const [fimHoras, fimMinutos] = fim.split(':').map(Number);
        
        const inicioTotal = inicioHoras * 60 + inicioMinutos;
        const fimTotal = fimHoras * 60 + fimMinutos;
        
        if (fimTotal > inicioTotal) {
            const diff = fimTotal - inicioTotal;
            const horas = Math.floor(diff / 60);
            const minutos = diff % 60;
            const duracao = horas + (minutos / 60);
            
            durationDisplay.innerHTML = `<strong>Duração Calculada:</strong> <span class="badge bg-success">${horas}h${minutos > 0 ? minutos + 'min' : ''} (${duracao.toFixed(1)}h)</span>`;
            
            // Habilitar botão de submit
            if (submitButton) {
                submitButton.disabled = false;
                submitButton.classList.remove('btn-danger');
                submitButton.classList.add('btn-primary');
            }
        } else {
            durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-warning">Hora fim deve ser maior que hora início</span>';
            
            // Desabilitar botão de submit
            if (submitButton) {
                submitButton.disabled = true;
                submitButton.classList.remove('btn-primary');
                submitButton.classList.add('btn-danger');
            }
        }
    } else {
        durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
        
        // Manter botão desabilitado se não tiver ambos os horários
        if (submitButton && (!inicio || !fim)) {
            submitButton.disabled = true;
            submitButton.classList.remove('btn-primary');
            submitButton.classList.add('btn-danger');
        }
    }
}

// Clear modal form
function clearModalForm() {
    document.getElementById('modal_hora_inicio').value = '';
    document.getElementById('modal_hora_fim').value = '';
    document.getElementById('modal_atividade_id').value = '';
    document.getElementById('modal_observacao').value = '';
    document.getElementById('modal_duration-display').innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
}

// Função para validar sobreposição de horários
function validarSobreposicaoHorarios(lancamentoIdAtual = null) {
    const dataSelecionada = document.getElementById('modal_data').value;
    const horaInicio = document.getElementById('modal_hora_inicio').value;
    const horaFim = document.getElementById('modal_hora_fim').value;
    
    if (!dataSelecionada || !horaInicio || !horaFim) {
        return { valido: true };
    }
    
    // Converter horários para minutos para comparação
    const [inicioHoras, inicioMinutos] = horaInicio.split(':').map(Number);
    const [fimHoras, fimMinutos] = horaFim.split(':').map(Number);
    const novoInicio = inicioHoras * 60 + inicioMinutos;
    const novoFim = fimHoras * 60 + fimMinutos;
    
    // Verificar se hora fim é maior que hora início
    if (novoFim <= novoInicio) {
        return { 
            valido: false, 
            mensagem: 'A hora de término deve ser maior que a hora de início.' 
        };
    }
    
    // Verificar sobreposição com lançamentos existentes do mesmo dia
    const linhas = document.querySelectorAll('tbody tr');
    
    for (const linha of linhas) {
        const dateCell = linha.querySelector('td:first-child .badge');
        if (!dateCell) continue;
        
        const dateStr = dateCell.textContent.trim();
        const [dia, mes, ano] = dateStr.split('/');
        const dataFormatada = `${ano}-${mes.padStart(2, '0')}-${dia.padStart(2, '0')}`;
        
        // Verificar se é do mesmo dia
        if (dataFormatada === dataSelecionada) {
            // Ignorar o lançamento sendo editado
            const editBtn = linha.querySelector('button[data-id]');
            const lancamentoId = editBtn ? editBtn.getAttribute('data-id') : null;
            
            if (lancamentoIdAtual && lancamentoId === lancamentoIdAtual) {
                continue; // Pula este lançamento (é o que está sendo editado)
            }
            
            const inicioExistente = linha.querySelector('td:nth-child(2)').textContent.trim();
            const fimExistente = linha.querySelector('td:nth-child(3)').textContent.trim();
            
            const [exInicioHoras, exInicioMinutos] = inicioExistente.split(':').map(Number);
            const [exFimHoras, exFimMinutos] = fimExistente.split(':').map(Number);
            
            const exInicio = exInicioHoras * 60 + exInicioMinutos;
            const exFim = exFimHoras * 60 + exFimMinutos;
            
            // Verificar sobreposição (exceto quando o novo início é igual ao fim do existente)
            const haSobreposicao = (
                (novoInicio >= exInicio && novoInicio < exFim) ||
                (novoFim > exInicio && novoFim <= exFim) ||
                (novoInicio <= exInicio && novoFim >= exFim)
            );
            
            // Verificar se é permitido (início do novo = fim do existente)
            const permitido = (novoInicio === exFim);
            
            if (haSobreposicao && !permitido) {
                return {
                    valido: false,
                    mensagem: `Conflito de horário: Já existe um lançamento das ${inicioExistente} às ${fimExistente} neste dia. Um novo lançamento só pode começar às ${fimExistente} ou depois.`
                };
            }
        }
    }
    
    return { valido: true };
}

