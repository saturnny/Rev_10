// Funções de edição e exclusão
function openEditModal(lancamentoId) {
    // Encontrar o botão de editar correspondente
    const editBtn = document.querySelector(`button[data-id="${lancamentoId}"]`);
    
    if (editBtn) {
        // Obter dados dos data attributes
        const data = editBtn.dataset.data;
        const inicio = editBtn.dataset.inicio;
        const fim = editBtn.dataset.fim;
        const atividadeId = editBtn.dataset.atividade;
        const observacao = editBtn.dataset.observacao || '';
        
        // Usar formato ISO (YYYY-MM-DD) para o input date
        document.getElementById('modal_data').value = data;
        document.getElementById('modal_hora_inicio').value = inicio;
        document.getElementById('modal_hora_fim').value = fim;
        document.getElementById('modal_atividade_id').value = atividadeId;
        document.getElementById('modal_observacao').value = observacao;
        
        // Travar campo de data
        document.getElementById('modal_data').readOnly = true;
        document.getElementById('modal_data').style.backgroundColor = '#f8f9fa';
        document.getElementById('modal_data').style.fontWeight = '500';
        
        // Configurar action do formulário
        document.getElementById('newLancamentoForm').action = `/editar-lancamento/${lancamentoId}`;
        
        // Mudar título do modal
        document.querySelector('#newLancamentoModal .modal-title').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Lançamento';
        
        // Mudar texto do botão de submit
        document.querySelector('#newLancamentoModal button[type="submit"]').innerHTML = '<i class="bi bi-check-circle me-1"></i>Atualizar Lançamento';
        
        // Abrir modal
        const modal = new bootstrap.Modal(document.getElementById('newLancamentoModal'));
        modal.show();
        
        // Inicializar time pickers para edição
        setTimeout(() => {
            initializeTimePickers(['modal_hora_inicio', 'modal_hora_fim']);
        }, 100);
    }
}

let deleteLancamentoId = null;

function deleteLancamento(lancamentoId) {
    deleteLancamentoId = lancamentoId;
    // Abrir modal de confirmação
    const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
    modal.show();
}

// Confirmar exclusão
document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
    if (deleteLancamentoId) {
        fetch(`/excluir-lancamento/${deleteLancamentoId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => {
            if (response.ok) {
                // Remover a linha da tabela
                const row = document.querySelector(`button[data-id="${deleteLancamentoId}"]`).closest('tr');
                row.remove();
                
                // Mostrar notificação
                showNotification('Lançamento excluído com sucesso!', 'success');
                
                // Atualizar estatísticas
                filterTodayLancamentos();
                
                // Fechar modal e remover backdrop completamente
                const modalElement = document.getElementById('deleteConfirmModal');
                const modal = bootstrap.Modal.getInstance(modalElement);
                modal.hide();
                
                // Garantir que o backdrop seja removido
                setTimeout(() => {
                    modal.dispose();
                    document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
                    document.body.classList.remove('modal-open');
                    document.body.style.overflow = '';
                    document.body.style.paddingRight = '';
                }, 300);
            } else {
                throw new Error('Erro ao excluir lançamento');
            }
        })
        .catch(error => {
            console.error('Erro:', error);
            alert('Erro ao excluir lançamento');
        });
    }
});

function updateEditDuration() {
    const inicio = document.getElementById('edit_hora_inicio').value;
    const fim = document.getElementById('edit_hora_fim').value;
    const durationDisplay = document.getElementById('edit_duration-display');
    
    if (inicio && fim) {
        const [inicioHoras, inicioMinutos] = inicio.split(':').map(Number);
        const [fimHoras, fimMinutos] = fim.split(':').map(Number);
        
        const inicioTotal = inicioHoras * 60 + inicioMinutos;
        const fimTotal = fimHoras * 60 + fimMinutos;
        
        if (fimTotal > inicioTotal) {
            const diff = fimTotal - inicioTotal;
            const horas = Math.floor(diff / 60);
            const minutos = diff % 60;
            const duracao = horas + (minutos / 60);
            
            durationDisplay.innerHTML = `<strong>Duração Calculada:</strong> <span class="badge bg-success">${horas}h${minutos > 0 ? minutos + 'min' : ''} (${duracao.toFixed(1)}h)</span>`;
        } else {
            durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-warning">Hora fim deve ser maior que hora início</span>';
        }
    } else {
        durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
    }
}

function clearEditForm() {
    const form = document.getElementById('editLancamentoForm');
    if (form) {
        form.reset();
        document.getElementById('edit_duration-display').innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
    }
}

// Event listeners para os botões
document.addEventListener('DOMContentLoaded', function() {
    // Botões de excluir (editar já tem onclick no HTML)
    document.querySelectorAll('.delete-btn-caneta').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.dataset.id;
            deleteLancamento(id);
        });
    });
});

function showNotification(message, type = 'info') {
    // Criar elemento de notificação
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : type === 'error' ? 'danger' : 'info'} alert-dismissible fade show position-fixed`;
    notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    notification.innerHTML = `
        <div class="d-flex align-items-center">
            <i class="bi ${type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-exclamation-triangle' : 'bi-info-circle'} me-2"></i>
            <div>${message}</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    document.body.appendChild(notification);
    
    // Auto remover após 5 segundos
    setTimeout(() => {
        notification.remove();
    }, 5000);
}
</script>
