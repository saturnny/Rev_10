<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Time Tracking System' %></title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Nosso CSS Customizado -->
    <link rel="stylesheet" href="/static/css/bootstrap-theme.css">
    <link rel="stylesheet" href="/static/css/icons.css">
    
    <% if (typeof extra_css !== 'undefined') { %>
        <%= extra_css %>
    <% } %>
</head>
<body>
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="app-layout">
        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-toggle" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">⏱️</div>
                    <span>Sistema de Atividades</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <% if (user.tipo_usuario === "Admin" || user.tipo_usuario === "Administrador") { %>
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Principal</div>
                    <a href="/dashboard" class="sidebar-item <%= (request && request.url && request.url.includes('/dashboard')) ? 'active' : '' %>">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">Administração</div>
                    <a href="/admin/usuarios" class="sidebar-item <%= (request && request.url && request.url.includes('/admin/usuarios')) ? 'active' : '' %>">
                        <i class="bi bi-person"></i>
                        <span>Usuários</span>
                    </a>
                    <a href="/admin/atividades" class="sidebar-item <%= (request && request.url && request.url.includes('/admin/atividades')) ? 'active' : '' %>">
                        <i class="bi bi-list-task"></i>
                        <span>Gerenciar Atividades</span>
                    </a>
                    <a href="/admin/categorias" class="sidebar-item <%= (request && request.url && request.url.includes('/admin/categorias')) ? 'active' : '' %>">
                        <i class="bi bi-tag"></i>
                        <span>Categorias</span>
                    </a>
                    <a href="/admin/lancamentos" class="sidebar-item <%= (request && request.url && request.url.includes('/admin/lancamentos')) ? 'active' : '' %>">
                        <i class="bi bi-clock-history"></i>
                        <span>Lançamentos da Equipe</span>
                    </a>
                </div>
                <% } else { %>
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Menu</div>
                    <a href="/dashboard" class="sidebar-item <%= (request && request.url && request.url.includes('/dashboard')) ? 'active' : '' %>">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="/lancamentos" class="sidebar-item <%= (request && request.url && request.url.includes('/lancamentos')) ? 'active' : '' %>">
                        <i class="bi bi-list-task"></i>
                        <span>Meus Lançamentos</span>
                    </a>
                    <a href="/perfil" class="sidebar-item <%= (request && request.url && request.url.includes('/perfil')) ? 'active' : '' %>">
                        <i class="bi bi-person"></i>
                        <span>Meu Perfil</span>
                    </a>
                </div>
                <% } %>
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar"><%= user.nome.substring(0, 2).toUpperCase() %></div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name"><%= user.nome %></div>
                        <div class="sidebar-user-role"><%= user.tipo_usuario %></div>
                    </div>
                </div>
                
                <div class="sidebar-logout">
                    <form method="post" action="/logout" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-outline-light">
                            <i class="bi bi-box-arrow-right"></i>
                            Sair
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
                    <% messages.forEach(function(message) { %>
                        <div class="alert alert-<%= message.type %> alert-dismissible fade show" role="alert">
                            <%= message.text %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% }); %>
                <% } %>
                
                <%= content %>
            </div>
        </main>
    </div>
    <% } else { %>
    <%= content %>
    <% } %>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Nosso JavaScript -->
    <script src="/static/js/app.js"></script>
    
    <% if (typeof extra_js !== 'undefined') { %>
        <%= extra_js %>
    <% } %>
</body>
</html>
