{% extends "base_bootstrap.html" %}

{% block title %}Meu Perfil - {{ user.nome }}{% endblock %}

{% block header %}
<div class="topbar">
    <div class="topbar-title">
        <h1>Meu Perfil</h1>
        <p>Visualize e gerencie suas informações pessoais</p>
    </div>
</div>
{% endblock %}

{% block content %}
<style>
.profile-container {
    height: calc(100vh - 200px);
    overflow: hidden;
    padding: 0;
}

.profile-header {
    background: linear-gradient(135deg, var(--bs-primary) 0%, var(--bs-primary-dark, #660000) 100%);
    color: white;
    padding: 30px 0;
    margin: -20px -20px 20px -20px;
    border-radius: 0 0 16px 16px;
}

.profile-header-content {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
    margin-left: 60px;
}

.profile-info {
    flex: 1;
    margin-left: 30px;
}

.profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: white;
    color: var(--bs-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: bold;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    border: 3px solid rgba(255,255,255,0.2);
    flex-shrink: 0;
    margin-left: 0;
}

.profile-name {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: white;
}

.profile-role {
    font-size: 1rem;
    opacity: 0.9;
    margin-bottom: 20px;
    color: white;
}

.profile-stats {
    display: flex;
    gap: 30px;
    margin-top: 20px;
}

.stat-item {
    text-align: left;
}

.stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 2px;
    color: white;
}

.stat-label {
    font-size: 0.8rem;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
}

.info-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.info-card {
    border: none;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
}

.info-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.info-card .card-header {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-bottom: none;
    padding: 16px 20px;
    border-radius: 12px 12px 0 0;
}

.info-card .card-body {
    padding: 20px;
}

.info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid #f0f0f0;
}

.info-item:last-child {
    border-bottom: none;
}

.info-label {
    font-size: 0.8rem;
    color: #6c757d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}

.info-value {
    font-size: 0.9rem;
    color: #212529;
    font-weight: 500;
}

.password-card {
    background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
    border: 2px solid #e9ecef;
}

.password-card .card-header {
    background: linear-gradient(135deg, var(--bs-primary) 0%, var(--bs-primary-dark, #660000) 100%);
    color: white;
    border: none;
}

.form-control {
    border-radius: 8px;
    border: 2px solid #e9ecef;
    padding: 10px 14px;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: var(--bs-primary);
    box-shadow: 0 0 0 0.2rem rgba(204, 20, 20, 0.25);
}

.btn-primary {
    background: linear-gradient(135deg, var(--bs-primary) 0%, var(--bs-primary-dark, #660000) 100%);
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(204, 20, 20, 0.3);
}

.alert {
    border-radius: 10px;
    border: none;
    padding: 12px 16px;
    margin-bottom: 16px;
}

.alert-success {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
}

.alert-danger {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
}

@media (max-width: 768px) {
    .profile-stats {
        gap: 20px;
    }
    
    .stat-value {
        font-size: 1.2rem;
    }
    
    .stat-label {
        font-size: 0.7rem;
    }
    
    .info-section {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    
    .profile-header-content {
        margin-left: 20px;
    }
}
</style>

<div class="profile-container">
    <!-- Header do Perfil -->
    <div class="profile-header">
        <div class="profile-header-content">
            <div class="profile-avatar">{{ user.nome[:2].upper() }}</div>
            
            <div class="profile-info">
                <div class="profile-name">{{ user.nome }}</div>
                <div class="profile-role">{{ user.tipo_usuario }}</div>
                
                <div class="profile-stats">
                    <div class="stat-item">
                        <div class="stat-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 300;">{{ user.equipe or 'N/A' }}</div>
                        <div class="stat-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">Equipe</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 300;">{{ user.area or 'N/A' }}</div>
                        <div class="stat-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">Área</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 300;">{{ user.especialidade or 'N/A' }}</div>
                        <div class="stat-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">Especialidade</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="info-section">
        <!-- Informações Pessoais -->
        <div class="card info-card">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Informações Pessoais
                </h3>
            </div>
            <div class="card-body">
                <div class="info-item">
                    <span class="info-label">Nome Completo</span>
                    <span class="info-value">{{ user.nome }}</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Email</span>
                    <span class="info-value">{{ user.email }}</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Tipo de Usuário</span>
                    <span class="info-value">
                        <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">
                            {{ user.tipo_usuario }}
                        </span>
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600;">Gestão</span>
                    <span class="info-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">{{ user.gestao or '-' }}</span>
                </div>
            </div>
        </div>

        <!-- Informações Profissionais -->
        <div class="card info-card">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="bi bi-briefcase me-2"></i>
                    Informações Profissionais
                </h3>
            </div>
            <div class="card-body">
                <div class="info-item">
                    <span class="info-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600;">Área</span>
                    <span class="info-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">
                        {% if user.area == 'Campo' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.area }}</span>
                        {% else %}
                            {{ user.area or '-' }}
                        {% endif %}
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600;">Equipe</span>
                    <span class="info-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">
                        {% if user.equipe == 'Auditoria' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.equipe }}</span>
                        {% elif user.equipe == 'Inspeção' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.equipe }}</span>
                        {% else %}
                            {{ user.equipe or '-' }}
                        {% endif %}
                    </span>
                </div>
                <div class="info-item">
                    <span class="info-label" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600;">Especialidade</span>
                    <span class="info-value" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 400;">
                        {% if user.especialidade == 'Auditoria' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.especialidade }}</span>
                        {% elif user.especialidade == 'Inspeção' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.especialidade }}</span>
                        {% elif user.especialidade == 'Campo' %}
                            <span class="badge bg-light text-dark" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 500;">{{ user.especialidade }}</span>
                        {% else %}
                            {{ user.especialidade or '-' }}
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Alteração de Senha -->
    <div class="card info-card password-card">
        <div class="card-header">
            <h3 class="card-title mb-0" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600; color: white;">
                <i class="bi bi-shield-lock me-2" style="color: white;"></i>
                Alterar Senha
            </h3>
        </div>
        
        <div class="card-body">
            {% if message %}
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                {{ message }}
            </div>
            {% endif %}
            
            {% if error %}
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                {{ error }}
            </div>
            {% endif %}
            
            <form method="post" action="/perfil">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="senha_atual" class="form-label">
                            <i class="bi bi-key me-1"></i>
                            Senha Atual
                        </label>
                        <input type="password" class="form-control" id="senha_atual" name="senha_atual" required>
                    </div>
                    <div class="col-md-4">
                        <label for="nova_senha" class="form-label">
                            <i class="bi bi-lock me-1"></i>
                            Nova Senha
                        </label>
                        <input type="password" class="form-control" id="nova_senha" name="nova_senha" required minlength="6">
                        <small class="text-muted">Mínimo 6 caracteres</small>
                    </div>
                    <div class="col-md-4">
                        <label for="confirmar_senha" class="form-label">
                            <i class="bi bi-lock-fill me-1"></i>
                            Confirmar Nova Senha
                        </label>
                        <input type="password" class="form-control" id="confirmar_senha" name="confirmar_senha" required>
                    </div>
                </div>
                
                <div class="d-flex gap-3 mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>
                        Atualizar Senha
                    </button>
                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-clockwise me-2"></i>
                        Limpar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
