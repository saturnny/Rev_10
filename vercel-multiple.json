{
  "version": 2,
  "functions": {
    "api/simple.py": {
      "runtime": "@vercel/python"
    },
    "api/flask.py": {
      "runtime": "@vercel/python"
    },
    "api/starlette.py": {
      "runtime": "@vercel/python"
    },
    "api/django.py": {
      "runtime": "@vercel/python"
    }
  },
  "routes": [
    {
      "src": "/simple/(.*)",
      "dest": "/api/simple.py"
    },
    {
      "src": "/flask/(.*)",
      "dest": "/api/flask.py"
    },
    {
      "src": "/starlette/(.*)",
      "dest": "/api/starlette.py"
    },
    {
      "src": "/django/(.*)",
      "dest": "/api/django.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/simple.py"
    }
  ]
}
